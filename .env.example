# =============================================================================
# Frontend (Vite)
# =============================================================================
# Local Supabase defaults (matches `supabase start` output)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_local_anon_key
# Legacy / hosted dashboard naming is also accepted, e.g.
# VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# "mock" forces the in-memory data store (no Supabase needed).
# Leave unset (or "supabase") to read from a real Supabase project.
# VITE_DATA_MODE=mock

# =============================================================================
# Edge function secrets (used by `supabase functions serve` and the deployed
# functions). Set these via `supabase secrets set KEY=value` for production.
# =============================================================================

# --- AI provider for the tutor / enrichment functions ---------------------
# Two ways to power real AI (pick ONE; the gateway is preferred):
#
# 1) Vercel AI Gateway (recommended, like the tazatelka / sciobot-next projects)
#    One key routes to OpenAI, Anthropic, and Google. Create it at
#    https://vercel.com/dashboard → AI → Gateway → API Keys.
AI_GATEWAY_API_KEY=
# Default provider prefix applied to bare model ids (e.g. "gpt-4o-mini" →
# "openai/gpt-4o-mini"). Set to "anthropic" or "google" to change the default.
AI_GATEWAY_PROVIDER=openai
#
# 2) Direct OpenAI. Used only when AI_GATEWAY_API_KEY is empty. When BOTH are
#    unset the edge function streams a deterministic mock response.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Radar ingestion
RSS_USER_AGENT=AI-Academy-Radar/0.1
